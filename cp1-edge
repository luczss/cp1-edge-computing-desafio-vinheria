#include <LiquidCrystal.h>

// Inicializa o display LCD com os pinos utilizados
// (RS, E, D4, D5, D6, D7)
LiquidCrystal lcd(12, 11, 10, 5, 4, 3, 2);

// Definição dos pinos dos componentes
int sensorLuz = A0;     // Sensor de luminosidade (LDR)
int ledVerde = 6;       // LED verde (ambiente ideal)
int ledAmarelo = 7;     // LED amarelo (nível de alerta)
int ledVermelho = 8;    // LED vermelho (excesso de luz)
int buzzer = 9;         // Buzzer para alertas sonoros

// Variáveis de controle
int valorLuz = 0;       // Valor bruto lido do sensor (0 a 1023)
int intensidade = 0;    // Intensidade de luz convertida em porcentagem

void setup() {
  // Inicializa o LCD (16 colunas e 2 linhas)
  lcd.begin(16, 2);

  // Configura os pinos
  pinMode(sensorLuz, INPUT);
  pinMode(ledVerde, OUTPUT);
  pinMode(ledAmarelo, OUTPUT);
  pinMode(ledVermelho, OUTPUT);
  pinMode(buzzer, OUTPUT);

  // Mensagem inicial exibida ao ligar o sistema
  lcd.setCursor(0, 0);
  lcd.print("Vinheria Agnello");
  lcd.setCursor(0, 1);
  lcd.print("Bem-vindo!");
  delay(3000); // Aguarda 3 segundos
}

void loop() {

  // Lê o valor do sensor de luz
  valorLuz = analogRead(sensorLuz);

  // Converte o valor (0–1023) para porcentagem invertida (100–0)
  // Quanto mais luz, menor a porcentagem
  intensidade = map(valorLuz, 0, 1023, 100, 0);

  // Atualiza o display
  lcd.clear();
  lcd.setCursor(0, 0);
  lcd.print("Luz: ");
  lcd.print(intensidade);
  lcd.print("%");

  lcd.setCursor(0, 1);

  // CONDIÇÃO 1: Ambiente escuro/ideal
  if (intensidade <= 30) {

    lcd.print("Ambiente OK");

    digitalWrite(ledVerde, HIGH);
    digitalWrite(ledAmarelo, LOW);
    digitalWrite(ledVermelho, LOW);

    noTone(buzzer); // Sem som
  }

  // CONDIÇÃO 2: Nível médio de luz (alerta)
  else if (intensidade <= 70) {

    lcd.print("Nivel ALERTA");

    digitalWrite(ledVerde, LOW);
    digitalWrite(ledAmarelo, HIGH);
    digitalWrite(ledVermelho, LOW);

    // Emite um alerta sonoro temporário
    tone(buzzer, 1000); // Frequência de 1000 Hz
    delay(3000);        // Dura 3 segundos
    noTone(buzzer);     // Para o som
  }

  // CONDIÇÃO 3: Excesso de luz
  else {

    lcd.print("MUITA LUZ!");

    digitalWrite(ledVerde, LOW);
    digitalWrite(ledAmarelo, LOW);
    digitalWrite(ledVermelho, HIGH);

    // Alerta sonoro contínuo mais agudo
    tone(buzzer, 2000); // Frequência de 2000 Hz
  }

  // Pequeno intervalo antes da próxima leitura
  delay(500);
}
